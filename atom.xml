  <entry>
    <title>欢迎来到不轲一逝的客栈</title>
    <link href="http://example.com/2021/12/31/%E6%AC%A2%E8%BF%8E%E6%9D%A5%E5%88%B0%E4%B8%8D%E8%BD%B2%E4%B8%80%E9%80%9D%E7%9A%84%E5%AE%A2%E6%A0%88/"/>
